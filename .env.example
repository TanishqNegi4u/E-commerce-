# Database
DB_USERNAME=shopwave
DB_PASSWORD=change_me_strong_password_here

# JWT Secret — MUST be at least 32 characters (256 bits for HS256)
# Generate a secure secret: openssl rand -hex 32
JWT_SECRET=replace_with_64_char_random_string_from_openssl_rand_hex_32

# Spring profile
SPRING_PROFILES_ACTIVE=prod

# ── Render.com / Production ────────────────────────────────────
# Set these in the Render dashboard environment variables section.
# Do NOT put real Render URLs in this file.
#
# Backend service:
#   DB_URL=jdbc:postgresql://<render-postgres-host>:5432/shopwave_db
#   DB_USERNAME=<render-postgres-user>
#   DB_PASSWORD=<render-postgres-password>
#   JWT_SECRET=<openssl rand -hex 32>
#   CORS_ORIGINS=https://your-frontend.onrender.com
#
# Frontend service (static site or web service):
#   REACT_APP_API_URL=https://your-backend.onrender.com/api
#
# ── Local Docker Compose ───────────────────────────────────────
# REACT_APP_API_URL is optional locally — defaults to http://localhost:8080/api
# REACT_APP_API_URL=http://localhost:8080/api